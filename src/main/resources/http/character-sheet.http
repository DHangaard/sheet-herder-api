### Get all character sheets - populated
GET {{url}}/character-sheets
Authorization: Bearer {{token}}

### Get character sheet by id
GET {{url}}/character-sheets/1
Authorization: Bearer {{token}}

### Get nonexistent character sheet (expect 404)
GET {{url}}/character-sheets/999
Authorization: Bearer {{token}}

### Update character sheet - all fields
PUT {{url}}/character-sheets/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Aragorn",
  "raceId": 1,
  "subraceId": null,
  "languageIds": [
    1,
    2
  ],
  "abilityScores": {
    "STR": 15,
    "DEX": 12,
    "CON": 14,
    "INT": 10,
    "WIS": 13,
    "CHA": 11
  },
  "notes": {
    "Session 1": "The party went to a castle..."
  }
}

### Update character sheet - notes only
PUT {{url}}/character-sheets/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "notes": {
    "Session 1": "The party went to a castle...",
    "Session 2": "They encountered a dragon."
  }
}

### Update another user's character sheet (expect 403)
PUT {{url}}/character-sheets/999
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Hacked"
}

### Update nonexistent character sheet (expect 404)
PUT {{url}}/character-sheets/999
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Ghost"
}

### Delete another user's character sheet (expect 403)
DELETE {{url}}/character-sheets/999
Authorization: Bearer {{token}}

### Delete nonexistent character sheet (expect 404)
DELETE {{url}}/character-sheets/999
Authorization: Bearer {{token}}

### Delete character sheet - Legolas (expect 204)
DELETE {{url}}/character-sheets/2
Authorization: Bearer {{token}}

### Get all character sheets - after delete
GET {{url}}/character-sheets
Authorization: Bearer {{token}}