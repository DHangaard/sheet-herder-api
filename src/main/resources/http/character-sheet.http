### Get all character sheets - empty (before creating any)
GET {{url}}/character-sheets
Authorization: Bearer {{token}}

### Create character sheet
POST {{url}}/character-sheets/
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Aragorn",
  "raceId": 6,
  "subraceId": null,
  "languageIds": [
    8,
    11
  ],
  "abilityScores": {
    "STR": 15,
    "DEX": 12,
    "CON": 14,
    "INT": 10,
    "WIS": 13,
    "CHA": 11
  }
}

